{
  "expo": {
    "name": "ICU Steward",
    "slug": "icu-steward",
    "scheme": "icu-steward",
    "version": "2.0.0",
    "orientation": "portrait",
    "userInterfaceStyle": "light",
    "plugins": ["expo-router"],
    "web": {
      "bundler": "metro"
    },
    "ios": {
      "supportsTablet": true,
      "bundleIdentifier": "com.icusteward.app"
    },
    "android": {
      "package": "com.icusteward.app",
      "backgroundColor": "#F4F6F9"
    },
    "extra": {
      "apiUrl": "https://icu-steward-api.onrender.com"
    }
  }
}
